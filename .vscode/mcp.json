{
  "servers": {
    "ado-stdio": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "${input:ado_organization}"
      ]
    },
    "azure-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "--registry",
        "https://registry.npmjs.org",
        "-y",
        "@azure/mcp@latest",
        "server",
        "start",
        "--namespace",
        "kusto",
        "--namespace",
        "monitor"
      ]
    },
    "code-quality-mcp": {
      "type": "http",
      "url": "https://code-quality-mcp.azurewebsites.net/",
      "headers": {
        "x-mcp-codequality-organization": "${input:ado_organization}",
        "x-mcp-codequality-project": "${input:ado_project}",
        "x-mcp-codequality-repository": "${input:ado_repository}"
      },
      "description": "CodeQuality analysis — search for anti-patterns and retrieve automated fix instructions. Also provides critical code path coverage and coverage improvement tools."
    },
    "code-search": {
      "url": "https://mcp.bluebird-ai.net/",
      "type": "http",
      "headers": {
        "x-mcp-ec-organization": "${input:ado_organization}",
        "x-mcp-ec-project": "${input:ado_project}",
        "x-mcp-ec-repository": "${input:ado_repository}",
        "x-mcp-ec-branch": "${input:ado_branch}"
      }
    },
    "deflaker": {
      "type": "stdio",
      "command": "dnx",
      "args": [
        "Deflaker@1.2026.518.1",
        "--yes",
        "--add-source",
        "https://msazure.pkgs.visualstudio.com/One/_packaging/Azure-Compute-Consumption/nuget/v3/index.json"
      ],
      "env": {
        "Organization": "${input:ado_organization}",
        "ProjectName": "${input:ado_project}",
        "RepositoryName": "${input:ado_repository}",
        "RepositoryPath": "${workspaceFolder}"
      }
    },
    "enghub": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure-core/enghub-mcp",
        "start"
      ],
      "description": "Engineering Hub documentation search. Published to the PIE-AECore-EngineeringHub-Consumption Azure Artifacts feed. One-time per-user setup (npm scope + Azure DevOps auth): see https://github.com/azure-core/enghub-mcp-server-tools#option-b-run-via-npx-no-install. Requires membership in the EngineeringHub-Users Entra group."
    },
    "ms-learn": {
      "url": "https://learn.microsoft.com/api/mcp",
      "type": "http"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "type": "stdio"
    },
    "pr-insights": {
      "url": "https://app-prinsights-01-mcp.azurewebsites.net/",
      "type": "http"
    },
    "stackoverflow": {
      "url": "https://stackoverflow.microsoft.com/mcp",
      "type": "http",
      "description": "Stack Overflow for Teams — search internal Q&A, articles, and knowledge base. Provides search, get_article, get_question, get_answers_by_question, and voting tools."
    },
    "unittest-mcp": {
      "type": "stdio",
      "command": "npx",
      "env": {
        "UNITTEST_MCP_SOURCE": "octane"
      },
      "args": [
        "-y",
        "unittest-mcp"
      ],
      "description": "AI-powered unit test generation and coverage analysis for Jest, Vitest, Pytest, and .NET. Provides run_tests, generate_test, generate_tests_batch, find_test_files, and inspect_coverage tools. Requires Node.js 18+."
    },
    "work-iq": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@microsoft/workiq",
        "mcp"
      ],
      "description": "Microsoft 365 data search - emails, meetings, documents, Teams messages. Requires tenant admin consent on first use. See https://github.com/microsoft/work-iq-mcp"
    }
  },
  "inputs": [
    {
      "id": "ado_organization",
      "type": "promptString",
      "description": "Azure DevOps Organization name",
      "password": false,
      "default": "ADO_ORG"
    },
    {
      "id": "ado_project",
      "type": "promptString",
      "description": "Azure DevOps Project name",
      "password": false,
      "default": "ADO_PROJECT"
    },
    {
      "id": "ado_repository",
      "type": "promptString",
      "description": "Azure DevOps Repository name",
      "password": false,
      "default": "ADO_REPO"
    },
    {
      "id": "ado_branch",
      "type": "promptString",
      "description": "Azure DevOps Branch name",
      "password": false,
      "default": "ADO_BRANCH"
    },
    {
      "id": "firstmate_guides_mcp_url",
      "type": "promptString",
      "description": "Deployed URL of the FirstMate Guides MCP server (serves precomputed PR-comment insights). Defaults to the production endpoint, which requires AzVPN + Entra auth.",
      "password": false,
      "default": "https://guidescontextserver-o3lq63o5pyvoe.azurewebsites.net/"
    }
  ]
}
