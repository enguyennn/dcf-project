# OpenAI API key for AI-powered assumption extraction
OPENAI_API_KEY=

# Alpha Vantage API key for market data retrieval
ALPHAVANTAGE_API_KEY=

# Allowed origin for CORS (defaults to '*' if unset)
ALLOWED_ORIGIN=
